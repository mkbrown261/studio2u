{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "studio2u",
  "compatibility_date": "2026-07-10",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "studio2u-production",
      "database_id": "be1bff4f-d218-4387-849d-2e3332d312df"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "studio2u-uploads"
    }
  ]
}
